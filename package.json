{
  "name": "medusa-plugin-elasticsearch",
  "packageManager": "yarn@3.2.4",
  "version": "1.0.0",
  "description": "Elasticsearch search plugin for Medusa v2",
  "author": "Peter Borodatyy <peterborodatyy@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/peterborodatyy/medusa-plugin-elasticsearch"
  },
  "bugs": {
    "url": "https://github.com/peterborodatyy/medusa-plugin-elasticsearch/issues"
  },
  "homepage": "https://github.com/peterborodatyy/medusa-plugin-elasticsearch",
  "license": "MIT",
  "keywords": [
    "medusa-plugin-integration",
    "medusa-plugin-search",
    "medusa-v2",
    "elasticsearch"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    },
    "./*": "./.medusa/server/src/*.js"
  },
  "files": [
    ".medusa",
    "!.medusa/server/src/**/__tests__"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" \"*.{json,mjs}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.{json,mjs}\"",
    "test": "jest",
    "test:integration": "jest --testPathPattern=__tests__ --forceExit"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^9.3.4"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "^2.5.0",
    "@medusajs/cli": "^2.5.0",
    "@medusajs/framework": "^2.5.0",
    "@medusajs/medusa": "^2.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@medusajs/admin-sdk": "^2.5.0",
    "@medusajs/cli": "^2.5.0",
    "@medusajs/framework": "^2.5.0",
    "@medusajs/js-sdk": "^2.5.0",
    "@medusajs/medusa": "^2.5.0",
    "@medusajs/test-utils": "^2.5.0",
    "@swc/core": "^1.5.7",
    "@types/jest": "^29.5.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/node_modules/"
    ],
    "moduleNameMapper": {
      "^(\\.\\.?/.*)\\.js$": "$1"
    },
    "rootDir": "src",
    "testRegex": "(/__tests__/.*|\\.(test|spec))\\.(ts|js)$",
    "transform": {
      ".ts": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "commonjs",
            "moduleResolution": "node"
          }
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  }
}
