{
  "name": "medusa-plugin-elasticsearch",
  "version": "1.0.0",
  "description": "Elasticsearch search plugin for Medusa v2",
  "author": "Peter Borodatyy <peterborodatyy@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/peterborodatyy/medusa-plugin-elasticsearch"
  },
  "bugs": {
    "url": "https://github.com/peterborodatyy/medusa-plugin-elasticsearch/issues"
  },
  "homepage": "https://github.com/peterborodatyy/medusa-plugin-elasticsearch",
  "license": "MIT",
  "keywords": [
    "medusa-plugin-integration",
    "medusa-v2",
    "elasticsearch"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./*": "./.medusa/server/src/*.js"
  },
  "files": [
    ".medusa",
    "!.medusa/server/src/**/__tests__"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "test": "jest"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.8.1"
  },
  "peerDependencies": {
    "@medusajs/framework": "^2.0.0",
    "@medusajs/medusa": "^2.0.0"
  },
  "devDependencies": {
    "@medusajs/framework": "^2.0.0",
    "@medusajs/medusa": "^2.0.0",
    "@medusajs/medusa-cli": "^2.0.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.6.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/node_modules/"
    ],
    "rootDir": "src",
    "testRegex": "(/__tests__/.*|\\.(test|spec))\\.(ts|js)$",
    "transform": {
      ".ts": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  }
}
